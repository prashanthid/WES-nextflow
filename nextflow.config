/*
 * nextflow.config
 * Container images, executor, and per-process resource defaults.
 * Tuned for a native Ubuntu (non-WSL) machine running everything through conda.
 * Adjust the executor block for your cluster (SLURM/SGE/AWS Batch/local).
 */

manifest {
    name        = 'wes-mutect2-strelka2-funcotator'
    description = 'Somatic WES calling with GATK Mutect2 + Strelka2 (Manta-assisted), Funcotator annotation'
    mainScript  = 'main.nf'
    nextflowVersion = '>=23.04.0'
}

docker.enabled = false
conda.enabled  = true
// Running natively — GATK/bcftools must be installed and on $PATH
// (e.g. activate the conda env: `conda activate wes-pipeline`) before launching Nextflow.
//
// Manta and Strelka2 get their OWN isolated conda environments (see the 'conda'
// directive on those two processes below), separate from the shared wes-pipeline
// env. This avoids a real boost-library version conflict that occurs when
// Manta/Strelka2 coexist in the same conda environment as GATK/bcftools (their
// dependency trees pull in different, incompatible boost versions). This applies
// regardless of OS, so it's kept here even outside WSL.
// Nextflow builds these environments automatically on first run (cached afterward
// under work/conda/ — expect the first MANTA/STRELKA2 run to take several extra
// minutes while the environment is built).
//
// Alternative: if you'd rather use Docker instead of conda (real Ubuntu makes this
// much simpler than WSL did — no WSL2/Docker Desktop integration needed), set
// docker.enabled = true instead and remove the two 'conda' lines below; the
// 'container' lines already present on each process will be used automatically.

// Default staging is 'symlink' (Nextflow's default) — deliberately NOT overridden
// to 'copy' here. Native Ubuntu filesystems support symlinks natively, so there's
// no reason to physically duplicate multi-GB reference files into every task's
// work directory. (This was force-set to 'copy' during earlier WSL1 troubleshooting
// due to a mistaken concern about symlink support there — not needed here.)

// ---------------------------------------------------------------------------
// Local executor cap. Set these to match YOUR machine's actual specs —
// the values below (68 cpus / 235 GB) were tuned for a specific 36-core/72-thread,
// 255 GB RAM machine from earlier in this setup. If this is different hardware,
// update both numbers accordingly (leave a few cores/GB of headroom for the OS).
// ---------------------------------------------------------------------------
executor {
    name      = 'local'
    cpus      = 68        // <-- set to (your total threads - a few, for OS headroom)
    memory    = '235 GB'  // <-- set to (your total RAM - ~20 GB headroom)
    queueSize = 8          // max number of processes Nextflow will submit concurrently
}

process {
    // Defaults
    cpus   = 4
    memory = '8 GB'
    time   = '4h'

    withName: 'BASE_RECALIBRATOR|APPLY_BQSR' {
        container = 'broadinstitute/gatk:4.5.0.0'
        cpus      = 6
        memory    = '16 GB'
    }

    withName: 'MUTECT2' {
        container = 'broadinstitute/gatk:4.5.0.0'
        cpus      = 12
        memory    = '32 GB'
        time      = '24h'
    }

    withName: 'LEARN_READ_ORIENTATION_MODEL|GET_PILEUP_SUMMARIES|CALCULATE_CONTAMINATION|FILTER_MUTECT_CALLS' {
        container = 'broadinstitute/gatk:4.5.0.0'
        cpus      = 4
        memory    = '8 GB'
    }

    withName: 'MANTA' {
        container = 'quay.io/biocontainers/manta:1.6.0--h9ee0642_1'
        conda     = 'bioconda::manta=1.6.0'
        cpus      = 16   // restored to full concurrency — the earlier WSL1 EFAULT
                          // issue that forced this down to 4 doesn't apply on real Linux
        memory    = '24 GB'
        time      = '8h'
    }

    withName: 'STRELKA2' {
        container = null
        conda     = null
        beforeScript = 'export PATH="/mnt/d/strelka-2.9.10.centos6_x86_64/bin:$PATH"'
        cpus      = 16   // restored to full concurrency — same as MANTA above.
                          // The pyflow subprocess-spawn EFAULT issue we hit was
                          // WSL1-specific (kernel syscall translation), not a
                          // Strelka2/pyflow bug — no reason to expect it on native Linux.
        memory    = '24 GB'
        time      = '8h'
    }

    withName: 'MERGE_STRELKA_VCFS' {
        container = 'quay.io/biocontainers/bcftools:1.19--h8b25389_0'
        cpus      = 2
        memory    = '4 GB'
    }

    withName: 'CONSENSUS_VCF' {
        container = 'quay.io/biocontainers/bcftools:1.19--h8b25389_0'
        cpus      = 2
        memory    = '4 GB'
    }

    withName: 'FUNCOTATOR' {
        container = 'broadinstitute/gatk:4.5.0.0'
        cpus      = 4
        memory    = '16 GB'
        time      = '4h'
    }
}

// Optional: switch to a scheduler, e.g.:
// process.executor = 'slurm'
// process.queue    = 'general'

params {
    // sensible defaults; override on the command line or with -params-file
    outdir = 'results'
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
